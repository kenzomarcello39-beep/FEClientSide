-- ========================== PLAYBACK ==========================
local TweenService = game:GetService("TweenService")

local EasingStyleMap = {
	[Enum.PoseEasingStyle.Linear] = Enum.EasingStyle.Linear,
	[Enum.PoseEasingStyle.Bounce] = Enum.EasingStyle.Bounce,
	[Enum.PoseEasingStyle.Cubic] = Enum.EasingStyle.Cubic,
	[Enum.PoseEasingStyle.Elastic] = Enum.EasingStyle.Elastic,
	[Enum.PoseEasingStyle.Constant] = Enum.EasingStyle.Linear,
}

local EasingDirectionMap = {
	[Enum.PoseEasingDirection.In] = Enum.EasingDirection.In,
	[Enum.PoseEasingDirection.Out] = Enum.EasingDirection.Out,
	[Enum.PoseEasingDirection.InOut] = Enum.EasingDirection.InOut,
}

function PlayKeyframeSequence(Model, KeyframeSequence, SpeedMult)
	SpeedMult = SpeedMult or 1
	
	local kfs = {}
	for _, kf in ipairs(KeyframeSequence:GetKeyframes()) do
		table.insert(kfs, {Time = kf.Time, KF = kf})
	end
	table.sort(kfs, function(a,b) return a.Time < b.Time end)
	
	if #kfs == 0 then return nil end
	
	local jointData = {}
	local motorMap = {}
	
	local function getMotor(poseName)
		if motorMap[poseName] then return motorMap[poseName] end
		for _, m in ipairs(Model:GetDescendants()) do
			if m:IsA("Motor6D") and m.Part1 and m.Part1.Name == poseName then
				motorMap[poseName] = m
				return m
			end
		end
		return nil
	end
	
	for _, entry in ipairs(kfs) do
		for _, pose in ipairs(entry.KF:GetDescendants()) do
			if pose:IsA("Pose") and pose.Weight > 0 then
				local motor = getMotor(pose.Name)
				if motor then
					if not jointData[pose.Name] then jointData[pose.Name] = {} end
					table.insert(jointData[pose.Name], {
						time = entry.Time,
						cframe = pose.CFrame,
						style = pose.EasingStyle,
						dir = pose.EasingDirection,
						motor = motor
					})
				end
			end
		end
	end
	
	local totalLen = kfs[#kfs].Time / SpeedMult
	local playing = true
	local startT = os.clock()
	local hb = nil
	
	hb = RunService.Heartbeat:Connect(function()
		if not playing or not Model or not Model.Parent then
			if hb then hb:Disconnect() end
			return
		end
		
		local t = ((os.clock() - startT) * SpeedMult) % totalLen
		
		for _, poses in pairs(jointData) do
			if #poses == 0 then continue end
			
			local prev = poses[1]
			local nxt = poses[1]
			for i = 1, #poses-1 do
				if t >= poses[i].time and t < poses[i+1].time then
					prev = poses[i]
					nxt = poses[i+1]
					break
				end
			end
			if t >= poses[#poses].time then
				prev = poses[#poses]
				nxt = poses[#poses]
			end
			
			local alpha = (nxt.time > prev.time) and (t - prev.time)/(nxt.time - prev.time) or 0
			local eased = TweenService:GetValue(alpha, EasingStyleMap[nxt.style] or Enum.EasingStyle.Linear, EasingDirectionMap[nxt.dir] or Enum.EasingDirection.InOut)
			
			prev.motor.Transform = prev.cframe:Lerp(nxt.cframe, eased)
		end
	end)
	
	return {
		Length = totalLen,
		Stop = function() 
			playing = false
			if hb then 
				hb:Disconnect() 
				hb = nil 
			end 
		end,
		Play = function() startT = os.clock() end
	}
end
