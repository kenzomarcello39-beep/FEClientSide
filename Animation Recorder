-- ========================== RECORDING ==========================
local recording = false
local keyframes = {}
local startTime = 0
local recordConnection = nil

local function solveTransform(desiredCF, motor)
	if not motor or not motor.Part0 then return CFrame.new() end
	local C0 = motor.C0
	local C1 = motor.C1
	local Part0CF = motor.Part0.CFrame
	return C0:Inverse() * Part0CF:Inverse() * desiredCF * C1
end

local function recordFrame()
	if not recording or not character or not character.Parent then return end
	
	local keyframe = Instance.new("Keyframe")
	keyframe.Time = tick() - startTime
	
	local rootPose = Instance.new("Pose")
	rootPose.Name = "HumanoidRootPart"
	rootPose.CFrame = CFrame.new()
	rootPose.Weight = 1
	
	local rootJoint = character.HumanoidRootPart:FindFirstChild("RootJoint")
	local torsoPose = Instance.new("Pose")
	torsoPose.Name = "Torso"
	torsoPose.CFrame = solveTransform(character.Torso.CFrame, rootJoint)
	torsoPose.Weight = 1
	torsoPose.Parent = rootPose
	
	local limbData = {
		{partName = "Head",          motorName = "Neck"},
		{partName = "Left Arm",      motorName = "Left Shoulder"},
		{partName = "Right Arm",     motorName = "Right Shoulder"},
		{partName = "Left Leg",      motorName = "Left Hip"},
		{partName = "Right Leg",     motorName = "Right Hip"}
	}
	
	for _, data in ipairs(limbData) do
		local part = character:FindFirstChild(data.partName)
		local motor = character.Torso:FindFirstChild(data.motorName)
		if part and motor then
			local pose = Instance.new("Pose")
			pose.Name = data.partName
			pose.CFrame = solveTransform(part.CFrame, motor)
			pose.Weight = 1
			pose.EasingStyle = Enum.PoseEasingStyle.Linear
			pose.EasingDirection = Enum.PoseEasingDirection.Out
			pose.Parent = torsoPose
		end
	end
	
	rootPose.Parent = keyframe
	table.insert(keyframes, keyframe)
end

